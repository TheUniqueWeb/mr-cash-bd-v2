rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Since our backend server operates using the Client SDK in the preview environment,
    // we allow read/write access to these specific collections to support both individual
    // document lookups and collection-wide queries.

    match /users/{username} {
      allow read, write: if true;
    }

    match /credentials/{username} {
      allow read, write: if true;
    }

    match /withdrawals/{withdrawalId} {
      allow read, write: if true;
    }

    match /postback_logs/{logId} {
      allow read, write: if true;
    }

    match /notifications/{notificationId} {
      allow read, write: if true;
    }
  }
}
